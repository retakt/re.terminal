# re.Term Server — Environment Variables

# Port the WebSocket/HTTP server listens on
TERMINAL_PORT=3003

# Password required to connect to the terminal
TERMINAL_PASSWORD=retaktppqq

# CORS origin — * for dev, set to your domain in production
TERMINAL_CORS_ORIGIN=*

# Root directory exposed to the file browser (defaults to $HOME)
FILE_ROOT=
SEARXNG_URL=https://search-api.retakt.cc
SHELL=cmd   # or cmd, or keep bash only if it's in your PATH
# Maximum number of concurrent PTY sessions
MAX_SESSIONS=10

# Maximum history lines per session
HISTORY_MAX=2000

# Default shell for PTY (bash, zsh, etc.)

# Log file path
LOG_FILE=re-term.log

# FalkorDB Settings (for Memory Graph visualization)
FALKORDB_URL=redis://localhost:6380
FALKORDB_GRAPH_NAME=GraphitiGraph

# Browser runtime agent model. Keep this separate from the chat model.
# ================================
# Browser Agent / Multi-Agent Browser Mode
# ================================

# Ollama-compatible API used by browser agents
# ================================
# Browser Agent Architecture
# ================================
BROWSER_AGENT_ORCHESTRATOR_ENABLED=true
BROWSER_AGENT_LEGACY_RUNTIME=false
BROWSER_AGENT_MAIN_HANDOFF_ENABLED=false
BROWSER_AGENT_EXECUTOR_LLM_ENABLED=false
BROWSER_AGENT_DISABLE_SEQUENCE=false
BROWSER_AGENT_MAX_SEQUENCE_STEPS=8

BROWSER_AGENT_SKIP_LOW_RISK_CHECKER=true
BROWSER_AGENT_SKIP_LOW_RISK_RESULT_CHECKER=true
BROWSER_AGENT_REPORT_STEP_FAST_PATH=true
BROWSER_AGENT_SYNTHETIC_LOW_RISK_STEPS=true
BROWSER_AGENT_SNAPSHOT_RESULT_FAST_PATH=true
BROWSER_AGENT_REPAIR_ATTEMPTS=0

# Default fallback

# Orchestrator / Llama

# Legacy compatibility

# Final Verifier / Llama or OpenAI-compatible

# Timeouts / generation
BROWSER_AGENT_TIMEOUT_MS=120000
BROWSER_AGENT_THINK=false
BROWSER_AGENT_NUM_CTX=16384
BROWSER_AGENT_NUM_PREDICT=1024
BROWSER_AGENT_MAIN_NUM_PREDICT=1024
BROWSER_AGENT_PLANNER_NUM_PREDICT=1024
BROWSER_AGENT_REVIEWER_NUM_PREDICT=1024
BROWSER_AGENT_RESULT_REVIEWER_NUM_PREDICT=1024
BROWSER_AGENT_FINAL_VERIFIER_NUM_PREDICT=1024

BROWSER_AGENT_MAIN_TEMPERATURE=0.25
BROWSER_AGENT_PLANNER_TEMPERATURE=0.15
BROWSER_AGENT_REVIEWER_TEMPERATURE=0.10
BROWSER_AGENT_RESULT_REVIEWER_TEMPERATURE=0.10
BROWSER_AGENT_FINAL_VERIFIER_TEMPERATURE=0.15

BROWSER_AGENT_TOP_P=0.9
BROWSER_AGENT_TOP_K=80
BROWSER_AGENT_REPEAT_PENALTY=1.08
# Preferred visible browser action layer
PLAYWRIGHT_MCP_ENABLED=true
PLAYWRIGHT_MCP_SCREENSHOT_ENABLED=false
# Keep Lightpanda/CDP available as fallback/read layer
LIGHTPANDA_NATIVE_MCP_ENABLED=false
LIGHTPANDA_CDP_URL=ws://127.0.0.1:9222
BROWSER_CDP_URL=ws://127.0.0.1:9222

# MCP settings
# Keep false if you manually start MCP servers.
# Set true only if you want the app to start external MCP itself.
EXTERNAL_MCP_AUTOSTART=true
EXTERNAL_MCP_CALL_TIMEOUT_MS=60000

MODEL_WARMUP_ENABLED=true
MODEL_WARMUP_SCOPE=active
MODEL_WARMUP_KEEP_ALIVE=10m
MODEL_WARMUP_TIMEOUT_MS=30000

BROWSER_AGENT_ENGINE_PRIORITY=playwright_mcp,lightpanda_cdp,chrome_cdp,static_fetch
BROWSER_ENGINE_HEALTH_TIMEOUT_MS=5000
BROWSER_CHROME_FALLBACK_ENABLED=true
BROWSER_ENABLE_CHROME_FALLBACK=true
BROWSER_CHROME_VISIBLE=true
BROWSER_CHROME_CDP_PORT=9223

# ================================
# Browser Agent Named Roles
# ================================

# Orchestrator / Llama
BROWSER_AGENT_ORCHESTRATOR_PERSONALITY=strategic,careful,concise,intent-focused
BROWSER_AGENT_ORCHESTRATOR_SKILLS=intent_decomposition,step_planning,risk_awareness

# Step Agent / Gemma
BROWSER_AGENT_STEP_AGENT_PERSONALITY=practical,browser-aware,action-focused
BROWSER_AGENT_STEP_AGENT_SKILLS=snapshot_reading,tool_selection,browser_action_planning

# Checker / Gemma
BROWSER_AGENT_CHECKER_PERSONALITY=skeptical,precise,safety-conscious
BROWSER_AGENT_CHECKER_SKILLS=command_validation,target_repair,risk_checking

# Watcher / Gemma
BROWSER_AGENT_WATCHER_PERSONALITY=visual,skeptical,evidence-first
BROWSER_AGENT_WATCHER_SKILLS=snapshot_verification,result_validation,repair_suggestion

BROWSER_AGENT_FINAL_VERIFIER_TEMPERATURE=0.15
BROWSER_AGENT_FINAL_VERIFIER_NUM_PREDICT=1024

# ================================
# Browser Agent Stable Role Routing
# ================================
BROWSER_AGENT_FINAL_VERIFIER_ENABLED=true
BROWSER_AGENT_FAST_SNAPSHOT_CHECKER=false
BROWSER_AGENT_CHECKER_RETRY_ON_INVALID_JSON=true

# Main Orchestrator / Llama
BROWSER_AGENT_ORCHESTRATOR_PROVIDER=ollama
BROWSER_AGENT_ORCHESTRATOR_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_ORCHESTRATOR_MODEL=llama3.2:latest

BROWSER_AGENT_MAIN_PROVIDER=ollama
BROWSER_AGENT_MAIN_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_MAIN_MODEL=llama3.2:latest

# Step Agent / fast vision model
BROWSER_AGENT_STEP_AGENT_PROVIDER=ollama
BROWSER_AGENT_STEP_AGENT_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_STEP_AGENT_MODEL=llama3.2:latest

# Checker / fast vision model
BROWSER_AGENT_CHECKER_PROVIDER=ollama
BROWSER_AGENT_CHECKER_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_CHECKER_MODEL=llama3.2:latest

# Watcher / fast vision model
BROWSER_AGENT_WATCHER_PROVIDER=ollama
BROWSER_AGENT_WATCHER_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_WATCHER_MODEL=llama3.2:latest

# Main Response / Final Verifier / Llama
BROWSER_AGENT_FINAL_VERIFIER_PROVIDER=ollama
BROWSER_AGENT_FINAL_VERIFIER_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_FINAL_VERIFIER_MODEL=llama3.2:latest

# Legacy compatibility aliases
BROWSER_AGENT_PLANNER_PROVIDER=ollama
BROWSER_AGENT_PLANNER_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_PLANNER_MODEL=llama3.2:latest

BROWSER_AGENT_REVIEWER_PROVIDER=ollama
BROWSER_AGENT_REVIEWER_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_REVIEWER_MODEL=llama3.2:latest

BROWSER_AGENT_RESULT_REVIEWER_PROVIDER=ollama
BROWSER_AGENT_RESULT_REVIEWER_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_RESULT_REVIEWER_MODEL=llama3.2:latest


