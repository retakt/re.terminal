# re.Term Server — Environment Variables

# Port the WebSocket/HTTP server listens on
TERMINAL_PORT=3003

# Password required to connect to the terminal
TERMINAL_PASSWORD=retaktppqq

# CORS origin — * for dev, set to your domain in production
TERMINAL_CORS_ORIGIN=*

# Root directory exposed to the file browser (defaults to $HOME)
FILE_ROOT=
SEARXNG_URL=https://search-api.retakt.cc
SHELL=cmd   # or cmd, or keep bash only if it's in your PATH
# Maximum number of concurrent PTY sessions
MAX_SESSIONS=10

# Maximum history lines per session
HISTORY_MAX=2000

# Default shell for PTY (bash, zsh, etc.)



# Log file path
LOG_FILE=re-term.log

# FalkorDB Settings (for Memory Graph visualization)
FALKORDB_URL=redis://localhost:6380
FALKORDB_GRAPH_NAME=GraphitiGraph

# Browser runtime agent model. Keep this separate from the chat model.
BROWSER_AGENT_BASE_URL=http://takt-pc.reverse-cliff.ts.net:11434
BROWSER_AGENT_MODEL=llama3.2:latest
BROWSER_AGENT_TIMEOUT_MS=60000
BROWSER_AGENT_THINK=false
BROWSER_AGENT_PLANNER_TEMPERATURE=0.10
BROWSER_AGENT_REPORTER_TEMPERATURE=0.25
BROWSER_AGENT_TOP_P=0.85
BROWSER_AGENT_TOP_K=40
BROWSER_AGENT_REPEAT_PENALTY=1.05
BROWSER_AGENT_NUM_CTX=8192
# BROWSER_AGENT_PLANNER_SYSTEM_PROMPT_PATH=server/config/browser-agent/browser-agent-planner.md
# BROWSER_AGENT_REPORTER_SYSTEM_PROMPT_PATH=server/config/browser-agent/browser-agent-reporter.md
LIGHTPANDA_CDP_URL=ws://127.0.0.1:9222
BROWSER_CDP_URL=ws://127.0.0.1:9222
BROWSER_AGENT_ENGINE_PRIORITY=lightpanda_cdp,chrome_cdp,static_fetch
BROWSER_ENGINE_HEALTH_TIMEOUT_MS=5000
BROWSER_CHROME_FALLBACK_ENABLED=false
BROWSER_CHROME_CDP_PORT=9223
LIGHTPANDA_NATIVE_MCP_ENABLED=false
PLAYWRIGHT_MCP_ENABLED=true
EXTERNAL_MCP_AUTOSTART=false
EXTERNAL_MCP_CALL_TIMEOUT_MS=30000
MODEL_WARMUP_ENABLED=true
MODEL_WARMUP_SCOPE=active
MODEL_WARMUP_KEEP_ALIVE=10m
MODEL_WARMUP_TIMEOUT_MS=20000

# Browser agent reasoning / timeout
BROWSER_AGENT_TIMEOUT_MS=180000
BROWSER_AGENT_NUM_CTX=32768
BROWSER_AGENT_NUM_PREDICT=4096
BROWSER_AGENT_THINK=true
BROWSER_AGENT_PLANNER_TEMPERATURE=0.15
BROWSER_AGENT_REPORTER_TEMPERATURE=0.2
BROWSER_AGENT_TOP_P=0.9
BROWSER_AGENT_REPEAT_PENALTY=1.08
BROWSER_AGENT_PLANNER_SYSTEM_PROMPT_PATH=server/config/prompts/browser-planner-system.md

# Prefer real visible browser for interactive tasks
BROWSER_CHROME_FALLBACK_ENABLED=true
BROWSER_ENABLE_CHROME_FALLBACK=true
BROWSER_CHROME_VISIBLE=true

# ================================
# Browser Agent Deep Reasoning Mode
# ================================

BROWSER_AGENT_TIMEOUT_MS=300000
BROWSER_AGENT_NUM_CTX=65536
BROWSER_AGENT_NUM_PREDICT=8192
BROWSER_AGENT_PLANNER_NUM_PREDICT=8192
BROWSER_AGENT_REPORTER_NUM_PREDICT=4096
BROWSER_AGENT_THINK=true

BROWSER_AGENT_PLANNER_TEMPERATURE=0.35
BROWSER_AGENT_REPORTER_TEMPERATURE=0.65

BROWSER_AGENT_TOP_P=0.95
BROWSER_AGENT_TOP_K=120
BROWSER_AGENT_REPEAT_PENALTY=1.12

BROWSER_AGENT_PLANNER_TOP_P=0.92
BROWSER_AGENT_PLANNER_TOP_K=100
BROWSER_AGENT_PLANNER_REPEAT_PENALTY=1.1

BROWSER_AGENT_REPORTER_TOP_P=0.98
BROWSER_AGENT_REPORTER_TOP_K=180
BROWSER_AGENT_REPORTER_REPEAT_PENALTY=1.08

BROWSER_AGENT_PLANNER_SYSTEM_PROMPT_PATH=server/config/prompts/browser-planner-system.md
BROWSER_AGENT_REPORTER_SYSTEM_PROMPT_PATH=server/config/prompts/browser-reporter-human.md

BROWSER_CHROME_FALLBACK_ENABLED=true
BROWSER_ENABLE_CHROME_FALLBACK=true
BROWSER_CHROME_VISIBLE=true
