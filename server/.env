# re.Term Server — Environment Variables

# Port the WebSocket/HTTP server listens on
TERMINAL_PORT=3003

# Password required to connect to the terminal
TERMINAL_PASSWORD=retaktppqq

# CORS origin — * for dev, set to your domain in production
TERMINAL_CORS_ORIGIN=*

# Root directory exposed to the file browser (defaults to $HOME)
FILE_ROOT=
SEARXNG_URL=https://search-api.retakt.cc
SHELL=cmd   # or cmd, or keep bash only if it's in your PATH
# Maximum number of concurrent PTY sessions
MAX_SESSIONS=10

# Maximum history lines per session
HISTORY_MAX=2000

# Default shell for PTY (bash, zsh, etc.)



# Log file path
LOG_FILE=re-term.log

# FalkorDB Settings (for Memory Graph visualization)
FALKORDB_URL=redis://localhost:6380
FALKORDB_GRAPH_NAME=GraphitiGraph

# Browser runtime agent model. Keep this separate from the chat model.
# ================================
# Browser Agent / Multi-Agent Browser Mode
# ================================

# Ollama-compatible API used by browser agents
BROWSER_AGENT_BASE_URL=https://chat-api.retakt.cc
OLLAMA_BASE_URL=https://chat-api.retakt.cc

# Main architecture switches
BROWSER_AGENT_LEGACY_RUNTIME=false
BROWSER_AGENT_MAIN_INTENT_ENABLED=true
BROWSER_AGENT_MAIN_HANDOFF_ENABLED=true
BROWSER_AGENT_EXECUTOR_LLM_ENABLED=false
BROWSER_AGENT_DISABLE_SEQUENCE=false
BROWSER_AGENT_MAX_SEQUENCE_STEPS=8

# Exact model names from your /api/tags
BROWSER_AGENT_MODEL=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
BROWSER_AGENT_MAIN_MODEL=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
BROWSER_AGENT_PLANNER_MODEL=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
BROWSER_AGENT_REVIEWER_MODEL=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
BROWSER_AGENT_EXECUTOR_MODEL=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
BROWSER_AGENT_RESULT_REVIEWER_MODEL=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
BROWSER_AGENT_REPORTER_MODEL=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b

# Thinking / context / timeout
BROWSER_AGENT_THINK=true
BROWSER_AGENT_TIMEOUT_MS=300000
BROWSER_AGENT_NUM_CTX=65536
BROWSER_AGENT_NUM_PREDICT=8192

# Stage-specific generation limits
BROWSER_AGENT_MAIN_NUM_PREDICT=4096
BROWSER_AGENT_PLANNER_NUM_PREDICT=4096
BROWSER_AGENT_REVIEWER_NUM_PREDICT=4096
BROWSER_AGENT_EXECUTOR_NUM_PREDICT=2048
BROWSER_AGENT_RESULT_REVIEWER_NUM_PREDICT=4096
BROWSER_AGENT_REPORTER_NUM_PREDICT=4096

# Stage temperatures
# Main intent can be more flexible. Planner/reviewer stay stable for JSON/tool calls.
BROWSER_AGENT_MAIN_TEMPERATURE=0.45
BROWSER_AGENT_PLANNER_TEMPERATURE=0.25
BROWSER_AGENT_REVIEWER_TEMPERATURE=0.15
BROWSER_AGENT_EXECUTOR_TEMPERATURE=0.10
BROWSER_AGENT_RESULT_REVIEWER_TEMPERATURE=0.25
BROWSER_AGENT_REPORTER_TEMPERATURE=0.35

# Global sampling defaults
BROWSER_AGENT_TOP_P=0.95
BROWSER_AGENT_TOP_K=120
BROWSER_AGENT_REPEAT_PENALTY=1.10

# Stage sampling overrides
BROWSER_AGENT_MAIN_TOP_P=0.95
BROWSER_AGENT_MAIN_TOP_K=120
BROWSER_AGENT_MAIN_REPEAT_PENALTY=1.10

BROWSER_AGENT_PLANNER_TOP_P=0.92
BROWSER_AGENT_PLANNER_TOP_K=100
BROWSER_AGENT_PLANNER_REPEAT_PENALTY=1.10

BROWSER_AGENT_REVIEWER_TOP_P=0.90
BROWSER_AGENT_REVIEWER_TOP_K=80
BROWSER_AGENT_REVIEWER_REPEAT_PENALTY=1.10

BROWSER_AGENT_EXECUTOR_TOP_P=0.85
BROWSER_AGENT_EXECUTOR_TOP_K=60
BROWSER_AGENT_EXECUTOR_REPEAT_PENALTY=1.08

BROWSER_AGENT_RESULT_REVIEWER_TOP_P=0.95
BROWSER_AGENT_RESULT_REVIEWER_TOP_K=120
BROWSER_AGENT_RESULT_REVIEWER_REPEAT_PENALTY=1.08

BROWSER_AGENT_REPORTER_TOP_P=0.95
BROWSER_AGENT_REPORTER_TOP_K=120
BROWSER_AGENT_REPORTER_REPEAT_PENALTY=1.08

# Prompt files
BROWSER_AGENT_PLANNER_SYSTEM_PROMPT_PATH=server/config/prompts/browser-planner-system.md
BROWSER_AGENT_REPORTER_SYSTEM_PROMPT_PATH=server/config/prompts/browser-reporter-human.md

# ================================
# Browser Engines / Playwright MCP / Lightpanda
# ================================

# Preferred visible browser action layer
PLAYWRIGHT_MCP_ENABLED=true

# Keep Lightpanda/CDP available as fallback/read layer
LIGHTPANDA_NATIVE_MCP_ENABLED=false
LIGHTPANDA_CDP_URL=ws://127.0.0.1:9222
BROWSER_CDP_URL=ws://127.0.0.1:9222

# MCP settings
# Keep false if you manually start MCP servers.
# Set true only if you want the app to start external MCP itself.
EXTERNAL_MCP_AUTOSTART=true
EXTERNAL_MCP_CALL_TIMEOUT_MS=60000

# Engine priority: Playwright first, Lightpanda still present, CDP/static fallback still present
BROWSER_AGENT_ENGINE_PRIORITY=playwright_mcp,lightpanda_cdp,chrome_cdp,static_fetch
BROWSER_ENGINE_HEALTH_TIMEOUT_MS=5000

# Visible Chrome fallback
BROWSER_CHROME_FALLBACK_ENABLED=true
BROWSER_ENABLE_CHROME_FALLBACK=true
BROWSER_CHROME_VISIBLE=true
BROWSER_CHROME_CDP_PORT=9223

# ================================
# Model Warmup
# ================================

MODEL_WARMUP_ENABLED=true
MODEL_WARMUP_SCOPE=active
MODEL_WARMUP_KEEP_ALIVE=10m
MODEL_WARMUP_TIMEOUT_MS=30000

BROWSER_AGENT_ORCHESTRATOR_ENABLED=true
BROWSER_AGENT_REPAIR_ATTEMPTS=1
BROWSER_AGENT_MAIN_HANDOFF_ENABLED=false