# re.Term Server — Environment Variables
# Copy this to .env and fill in your values

# Port the WebSocket/HTTP server listens on
TERMINAL_PORT=3003

# Password required to connect to the terminal
# CHANGE THIS TO A STRONG RANDOM VALUE BEFORE DEPLOYING
# Use: openssl rand -base64 32
TERMINAL_PASSWORD=changeme

# CORS origin — set to your frontend domain in production
# Use * for development only
TERMINAL_CORS_ORIGIN=https://your-domain.com

# Root directory exposed to the file browser (defaults to $HOME)
# FILE_ROOT=/path/to/exposed/directory

# SearXNG instance used by MCP web search.
# If omitted, the server falls back to config/services.json.
SEARXNG_URL=https://search-api.retakt.cc

# Maximum number of concurrent PTY sessions
MAX_SESSIONS=10

# Maximum history lines per session
HISTORY_MAX=2000

# Default shell for PTY (bash, zsh, etc.)
SHELL=bash

# Log file path
LOG_FILE=re-term.log

# Optional long-term memory.
# The app still starts when this is off or when FalkorDB is unavailable.
MEMORY_ENABLED=true
MEMORY_PROVIDER=falkordb
MEMORY_PROJECT_ID=default-user
MEMORY_TIMEOUT_MS=1500

# If you start graphiti/docker-compose.yml on the same host, keep these defaults.
FALKORDB_HOST=127.0.0.1
FALKORDB_PORT=6380
FALKORDB_DATABASE=graphiti_memory
FALKORDB_PASSWORD=
