# re.Term Server — Environment Variables
# Copy this to .env and fill in your values

# Port the WebSocket/HTTP server listens on
TERMINAL_PORT=3003

# Password required to connect to the terminal
# CHANGE THIS TO A STRONG RANDOM VALUE BEFORE DEPLOYING
# Use: openssl rand -base64 32
TERMINAL_PASSWORD=changeme

# CORS origin — set to your frontend domain in production
# Use * for development only
TERMINAL_CORS_ORIGIN=https://your-domain.com

# Root directory exposed to the file browser (defaults to $HOME)
# FILE_ROOT=/path/to/exposed/directory

# SearXNG instance used by MCP web search.
# If omitted, the server falls back to config/services.json.
SEARXNG_URL=https://search-api.retakt.cc

# Lightpanda-first browser runtime.
LIGHTPANDA_CDP_URL=ws://127.0.0.1:9222
BROWSER_CDP_URL=ws://127.0.0.1:9222
BROWSER_AGENT_ENGINE_PRIORITY=lightpanda_cdp,static_fetch
BROWSER_ENGINE_HEALTH_TIMEOUT_MS=5000

# Chrome is a manual fallback only. Health checks and browser-agent status do
# not start Chrome unless you explicitly opt into chrome_cdp.
BROWSER_CHROME_FALLBACK_ENABLED=false
BROWSER_CHROME_CDP_PORT=9223

# Native Lightpanda MCP exists in the binary, but this app has no stdio bridge
# wired yet. Keep this disabled until a real adapter is implemented.
LIGHTPANDA_NATIVE_MCP_ENABLED=false

# Optional separate runtime model for the browser agent.
# The current browser-agent is deterministic-only and does not call this model.
BROWSER_AGENT_LLM_ENABLED=false
BROWSER_AGENT_BASE_URL=https://browser-agent-api.retakt.cc
BROWSER_AGENT_MODEL=qwen3.5
BROWSER_AGENT_TIMEOUT_MS=60000
BROWSER_AGENT_THINK=false

# Fire-and-forget model warmup when a chat prompt is sent.
# Browser-agent runtime warmup is skipped because no browser-agent model is used.
# all = every model returned by /api/tags from the configured endpoint(s).
MODEL_WARMUP_ENABLED=true
MODEL_WARMUP_SCOPE=active
MODEL_WARMUP_KEEP_ALIVE=10m
MODEL_WARMUP_TIMEOUT_MS=20000

# Maximum number of concurrent PTY sessions
MAX_SESSIONS=10

# Maximum history lines per session
HISTORY_MAX=2000

# Default shell for PTY (bash, zsh, etc.)
SHELL=bash

# Log file path
LOG_FILE=re-term.log

# Optional long-term memory.
# The app still starts when this is off or when FalkorDB is unavailable.
MEMORY_ENABLED=true
MEMORY_PROVIDER=falkordb
MEMORY_PROJECT_ID=default-user
MEMORY_TIMEOUT_MS=1500

# If you start graphiti/docker-compose.yml on the same host, keep these defaults.
FALKORDB_HOST=127.0.0.1
FALKORDB_PORT=6380
FALKORDB_DATABASE=graphiti_memory
FALKORDB_PASSWORD=
