FALKORDB_DATABASE=graphiti_memory
GRAPHITI_GROUP_ID=reterm
SEMAPHORE_LIMIT=2
GRAPHITI_TELEMETRY_ENABLED=false

# Graphiti MCP uses OpenAI-compatible clients for local/Ollama-style models.
# chat-api.retakt.cc exposes both native Ollama /api/* and OpenAI-compatible /v1/*.
OPENAI_API_KEY=ollama
OPENAI_BASE_URL=https://chat-api.retakt.cc/v1
MODEL_NAME=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
SMALL_MODEL_NAME=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b

# If your Graphiti MCP image supports OpenAI-compatible embeddings, set these.
# Otherwise keep Graphiti MCP disabled and let the Node app write Falkor memories.
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIM=768
