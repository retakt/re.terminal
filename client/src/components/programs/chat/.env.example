# ── Chat Configuration ────────────────────────────────────────────────────────
# Copy this file to .env.local and update the values

# Ollama API URL (direct connection)
# For local development: http://localhost:11434
# For production via server proxy: leave empty (uses /api/ollama/*)
VITE_OLLAMA_URL=http://localhost:11434

# SearXNG web search URL
# For local development: http://localhost:8080
# Leave empty to disable web search
VITE_SEARXNG_URL=http://localhost:8080

# Default Ollama model
VITE_MODEL_ID=joe-speedboat/Gemma-4-Uncensored-HauhauCS-Aggressive:e4b
